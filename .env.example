# ================================================
# KartOps - Variáveis de Ambiente
# ================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para .env (na raiz do projeto)
#   2. Preencha com seus valores reais
#   3. NUNCA suba o .env para o Git
#   4. No servidor, faça upload do .env via FTP/SFTP manualmente
# ================================================

# --- Banco de Dados ---
DB_HOST=localhost
DB_NAME=datakart
DB_USER=root
DB_PASS=
DB_PORT=3306
DB_CHARSET=utf8mb4

# --- Aplicação ---
APP_NAME=KartOps
APP_URL=https://sistema.oskarteiro.com.br
APP_VERSION=1.6
TIMEZONE=America/Sao_Paulo

# --- SMTP (Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
MAIL_FROM=noreply@kartops.com
MAIL_NAME=KartOps
MAIL_DEBUG=false

# --- Google OAuth (Login Social) ---
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# --- Google Drive (API Key para fotos) ---
GOOGLE_DRIVE_API_KEY=sua_api_key_do_google_drive

# --- Remove BG (Remoção de fundo de imagem) ---
REMOVE_BG_API_KEY=sua_api_key_do_remove_bg
